#!/bin/sh

# 开机时只判断一次网络连接方式。
# eth0 已连接网线时使用有线网络，否则使用 Wi-Fi。

CONFIG_FILE="/etc/wifi.conf"
ETH_CARRIER_WAIT_SEC=3

wlan_mac=$(fw_printenv -n wlanmac 2>/dev/null)

set_env_if_changed() {
    name="$1"
    value="$2"

    # 仅在参数变化时写入 Flash，避免每次开机重复擦写环境区。
    if [ "$(fw_printenv -n "$name" 2>/dev/null)" = "$value" ]; then
        return 0
    fi

    fw_setenv "$name" "$value"
}

stop_eth0() {
    ifdown -f eth0 >/dev/null 2>&1
    ip addr flush dev eth0 2>/dev/null
    ifconfig eth0 down 2>/dev/null
}

stop_wifi() {
    ifdown -f wlan0 >/dev/null 2>&1
    ip addr flush dev wlan0 2>/dev/null
    ifconfig wlan0 down 2>/dev/null
}

start_eth0() {
    stop_wifi
    ifup eth0
}

eth0_connected() {
    count=0

    ifconfig eth0 up 2>/dev/null || return 1

    while [ "$count" -lt "$ETH_CARRIER_WAIT_SEC" ]; do
        if [ "$(cat /sys/class/net/eth0/carrier 2>/dev/null)" = "1" ]; then
            return 0
        fi

        count=$((count + 1))
        sleep 1
    done

    return 1
}

start_wifi() {
    stop_eth0

    [ -r "$CONFIG_FILE" ] || return 1
    . "$CONFIG_FILE"

    set_env_if_changed wlanssid "$WIFI_SSID" || return 1
    set_env_if_changed wlanpass "$WIFI_PASSWORD" || return 1

    if /etc/wireless/usb "$WIFI_DEVICE" || /etc/wireless/sdio "$WIFI_DEVICE"; then
        [ -n "$wlan_mac" ] && ip link set dev wlan0 address "$wlan_mac"
        ifup wlan0
        return $?
    fi

    return 1
}

start() {
    echo "Starting network..."
    ifup lo

    if eth0_connected; then
        echo "Using wired network."
        start_eth0
    else
        echo "Using Wi-Fi network."
        start_wifi
    fi
}

stop() {
    echo "Stopping network..."
    stop_wifi
    stop_eth0
    ifdown -f usb0 >/dev/null 2>&1
    ifdown -f eth1 >/dev/null 2>&1
    ifdown lo
}

case "$1" in
    start|stop)
        "$1"
        ;;
    restart|reload)
        stop
        start
        ;;
    *)
        echo "Usage: $0 {start|stop|restart|reload}"
        exit 1
        ;;
esac
